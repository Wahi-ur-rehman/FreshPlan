# ─────────────────────────────────────────────────────────────────────────────
# FreshPlan .gitignore
# CRITICAL: Never commit API keys, tokens, or secrets to git.
# Use --dart-define at build time for all secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
.env.*
*.env
.envrc
secrets.json
*secrets*
*secret*
google-services.json
GoogleService-Info.plist
supabase/.env

# ── Flutter / Dart ────────────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.iml
*.log

# ── Android ───────────────────────────────────────────────────────────────────
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/*.keystore
**/*.jks

# ── iOS ────────────────────────────────────────────────────────────────────────
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*
Podfile.lock

# ── macOS ──────────────────────────────────────────────────────────────────────
**/macos/Flutter/GeneratedPluginRegistrant.swift
**/macos/Flutter/ephemeral

# ── Web ────────────────────────────────────────────────────────────────────────
lib/generated_plugin_registrant.dart

# ── VS Code ────────────────────────────────────────────────────────────────────
.vscode/settings.json
# Keep .vscode/launch.json if it only has debug configs (no secrets)
# But ensure --dart-define values are NOT checked in there either

# ── IDE ────────────────────────────────────────────────────────────────────────
.idea/
*.ipr
*.iws
.DS_Store

# ── Supabase ───────────────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
# supabase/migrations/ — DO commit migrations (they're safe)
# supabase/edge_functions/ — DO commit edge functions (keys are in env vars)

# ── Debug symbols (from obfuscated builds) ────────────────────────────────────
symbols/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.supabase/
