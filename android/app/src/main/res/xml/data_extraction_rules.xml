<?xml version="1.0" encoding="utf-8"?>
<!--
  data_extraction_rules.xml  (Android 12+)
  ─────────────────────────────────────────
  Controls what data is included in backups and device-to-device transfers.
  We exclude everything sensitive.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="cache" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Allow device-to-device transfer only for non-sensitive prefs -->
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="flutter_secure_storage" />
    </device-transfer>
</data-extraction-rules>
